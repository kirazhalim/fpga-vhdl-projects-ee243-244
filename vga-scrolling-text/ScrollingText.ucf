#
# Pin assignments for the Nexys3 Board.
#
net reset loc=B8; # Push-Button BTNS
net clk loc=V10; # 100 MHz board clock
net vsync loc=P7; # VGA-VSYNC
net hsync loc=N6; # VGA-HSYNC
net rgb(7) loc=U7; # VGA-RED0
net rgb(6) loc=V7; # VGA-RED1
net rgb(5) loc=N7; # VGA-RED2
net rgb(4) loc=P8; # VGA-GRN0
net rgb(3) loc=T6; # VGA-GRN1
net rgb(2) loc=V6; # VGA-GRN2
net rgb(1) loc=R7; # VGA-BLU1
net rgb(0) loc=T7; # VGA-BLU2